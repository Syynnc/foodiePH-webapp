# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Anon/public key — used for client-side auth and row-level security queries
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Service role key — has full DB access, NEVER expose to the browser
# Used only in server-side API routes and admin operations
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Database ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL (port 5432) for serverless/edge environments

DATABASE_URL="postgresql://postgres.your-project-ref:your-db-password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ── Node.js ───────────────────────────────────────────────────────────────────
# Prefer IPv4 when resolving DNS — fixes connection issues on some networks/ISPs
NODE_OPTIONS="--dns-result-order=ipv4first"

